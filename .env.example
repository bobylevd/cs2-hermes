# ---------------------------------------------------------------------------
# Runtime environment, shared by both containers (env_file: .env).
# Copy to `.env` next to docker-compose.yml and fill in.
# ---------------------------------------------------------------------------

# ===== CS2 dedicated server (cs2 container) =================================
TICKRATE=128
MAXPLAYERS=24
API_KEY=""            # Steam Web API key — only for Workshop map downloads
STEAM_ACCOUNT=""      # GSLT — only for public/online play
LAN=0                 # 1 = LAN-only (no GSLT needed)
SERVER_PASSWORD=""    # join password ("" = public)
PORT=27015
EXEC=on_boot.cfg

# ===== RCON (server admin password + how Hermes reaches the server) =========
# REQUIRED. Strong value — it is the server admin password.
RCON_PASSWORD="change-me-please"
RCON_HOST=cs2         # the cs2 service name (Docker network DNS)
RCON_PORT=27015

# ===== Hermes container ownership (align with the cs2 volume's steam uid) ===
PUID=1000
PGID=1000

# ===== Hermes LLM backend (OpenAI-compatible by default) ====================
# Default: "Kimi for Coding" (Kimi Code API — a SEPARATE endpoint from regular
# Kimi/Moonshot). Model id is always `kimi-for-coding`. Get the key from your
# Kimi Code subscription (sk-kim...). Sanity-check a key with:
#   curl https://api.kimi.com/coding/v1/models -H "Authorization: Bearer <KEY>"
#
# Other backends:
#   Regular Kimi/Moonshot: HERMES_BASE_URL=https://api.moonshot.ai/v1  MODEL=kimi-k2-0711-preview
#   OpenAI Codex:          HERMES_PROVIDER=openai-codex  HERMES_BASE_URL=  MODEL=gpt-5-codex
HERMES_PROVIDER=custom
HERMES_BASE_URL=https://api.kimi.com/coding/v1
HERMES_MODEL=kimi-for-coding
HERMES_API_KEY=""

# ===== Hermes gateway (how you send commands) ===============================
GATEWAY_PLATFORM=telegram      # telegram | discord
TELEGRAM_BOT_TOKEN=""
DISCORD_BOT_TOKEN=""

# Sender allowlist. The gateway DENIES unknown senders by default (this bot can
# shell into and admin your server, so that's the safe default). Put YOUR numeric
# Telegram user id here — get it by messaging @userinfobot on Telegram.
# Comma-separate multiple ids.
TELEGRAM_ALLOWED_USERS=""
DISCORD_ALLOWED_USERS=""
# Escape hatch: set to true to allow ANYONE who finds the bot to command it.
# Insecure for a server-admin bot — prefer the allowlist above. Leave false.
GATEWAY_ALLOW_ALL_USERS=false

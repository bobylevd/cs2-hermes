# ---------------------------------------------------------------------------
# Runtime environment for the CS2-modded-server + Hermes admin image.
# Copy to `.env` next to docker-compose.hermes.yml and fill in.
# Nothing here is baked into the image.
# ---------------------------------------------------------------------------

# ===== CS2 dedicated server (kus/cs2-modded-server) =========================
TICKRATE=128
MAXPLAYERS=24
API_KEY=""            # Steam Web API key — only for Workshop map downloads
STEAM_ACCOUNT=""      # GSLT — only for public/online play
LAN=0                 # 1 = LAN-only (no GSLT needed)
SERVER_PASSWORD=""    # join password ("" = public)

# ===== RCON (server admin password + how Hermes controls the live server) ===
# REQUIRED. Strong value — it is the server admin password.
RCON_PASSWORD="change-me-please"
RCON_HOST=127.0.0.1   # correct for the single-container setup
RCON_PORT=27015

# ===== Hermes LLM backend (OpenAI-compatible by default) ====================
#   Kimi-for-coding (Moonshot):
#     HERMES_PROVIDER=custom
#     HERMES_BASE_URL=https://api.moonshot.ai/v1
#     HERMES_MODEL=kimi-k2-0711-preview
#   OpenAI Codex:
#     HERMES_PROVIDER=openai-codex
#     HERMES_BASE_URL=
#     HERMES_MODEL=gpt-5-codex
HERMES_PROVIDER=custom
HERMES_BASE_URL=https://api.moonshot.ai/v1
HERMES_MODEL=kimi-k2-0711-preview
HERMES_API_KEY=""

# ===== Hermes gateway (how you send commands) ===============================
GATEWAY_PLATFORM=telegram      # telegram | discord
TELEGRAM_BOT_TOKEN=""
DISCORD_BOT_TOKEN=""

# Sender allowlist. The gateway DENIES unknown senders by default (this bot can
# shell into and admin your server, so that's the safe default). Put YOUR numeric
# Telegram user id here — get it by messaging @userinfobot on Telegram.
# Comma-separate multiple ids.
TELEGRAM_ALLOWED_USERS=""
DISCORD_ALLOWED_USERS=""
# Escape hatch: set to true to allow ANYONE who finds the bot to command it.
# Insecure for a server-admin bot — prefer the allowlist above. Leave false.
GATEWAY_ALLOW_ALL_USERS=false
